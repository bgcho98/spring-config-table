<idea-plugin>
    <id>com.pinkmandarin.sct</id>
    <name>Spring Config Table</name>
    <vendor url="https://github.com/pinkmandarin/spring-config-table">PinkMandarin</vendor>
    <resource-bundle>messages.SctBundle</resource-bundle>
    <description><![CDATA[
        <p>Manage Spring Boot multi-environment YAML config files using a single Markdown table.</p>
        <ul>
            <li><b>Visual Table Editor</b> — Master-Detail layout with grouped property list and inline editing</li>
            <li><b>YAML Lens</b> — View YAML/Markdown files as a searchable property table</li>
            <li><b>YAML &harr; Markdown Migration</b> — Convert with comment preservation</li>
            <li><b>Auto-Generation</b> — Regenerates YAML on master file change</li>
            <li><b>Spring Metadata</b> — Type detection from spring-configuration-metadata.json</li>
            <li><b>Comment Round-Trip</b> — YAML # comments &harr; Markdown &lt;!-- comments --&gt;</li>
        </ul>
    ]]></description>

    <change-notes><![CDATA[
        <h3>1.0.0</h3>
        <ul>
            <li>Initial release</li>
            <li>Visual table editor with Master-Detail layout</li>
            <li>YAML Lens viewer with search, filter, natural sort</li>
            <li>YAML &harr; Markdown migration with comments</li>
            <li>Spring Boot metadata integration</li>
            <li>Configurable environment sorting (lifecycle &times; region)</li>
            <li>Auto-generation with debounce</li>
            <li>Multi-module support</li>
            <li>i18n: English + Korean</li>
        </ul>
    ]]></change-notes>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <backgroundPostStartupActivity
                implementation="com.pinkmandarin.sct.intellij.SctStartupActivity"/>
        <projectConfigurable
                instance="com.pinkmandarin.sct.intellij.SctConfigurable"
                id="com.pinkmandarin.sct.settings"
                displayName="Spring Config Table"
                parentId="tools"/>
        <projectService
                serviceImplementation="com.pinkmandarin.sct.intellij.SctSettings"/>
        <projectService
                serviceImplementation="com.pinkmandarin.sct.intellij.SctFileWatcher"/>
        <projectService
                serviceImplementation="com.pinkmandarin.sct.intellij.editor.SpringMetadataService"/>
        <fileEditorProvider
                implementation="com.pinkmandarin.sct.intellij.editor.SctEditorProvider"/>
        <notificationGroup id="sct"
                           displayType="BALLOON"
                           isLogByDefault="true"/>
    </extensions>

    <actions>
        <action id="com.pinkmandarin.sct.GenerateYaml"
                class="com.pinkmandarin.sct.intellij.GenerateYamlAction"
                icon="/icons/generate.svg">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <action id="com.pinkmandarin.sct.YamlLens"
                class="com.pinkmandarin.sct.intellij.YamlLensAction"
                icon="/icons/yamlLens.svg">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
        <action id="com.pinkmandarin.sct.OpenTableEditor"
                class="com.pinkmandarin.sct.intellij.OpenTableEditorAction"
                icon="/icons/sct.svg">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <action id="com.pinkmandarin.sct.MigrateToMarkdown"
                class="com.pinkmandarin.sct.intellij.MigrateToMarkdownAction"
                icon="/icons/migrate.svg">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
